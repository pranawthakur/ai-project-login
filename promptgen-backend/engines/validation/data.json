    {
      "columns": [
        "Tier",
        "Trigger",
        "Behavior"
      ],
      "rows": [
        {
          "Tier": "green",
          "Trigger": "Full intake, cleared, \u22658 weeks consistent check-ins",
          "Behavior": "Full autoregulation, advanced techniques allowed (file 6) permitted"
        },
        {
          "Tier": "yellow",
          "Trigger": "Partial intake OR <8 weeks history OR 1 missed check-in cycle",
          "Behavior": "Conservative progression, cap intensity techniques, re-request missing data"
        },
        {
          "Tier": "orange",
          "Trigger": "`pending_clearance`, `medical_disclosure_refused`, or 2 missed check-in cycles",
          "Behavior": "DEFAULT_SAFE_TEMPLATE only, no advanced techniques, no aggressive deficits, repeat clearance/disclosure request each session"
        },
        {
          "Tier": "red",
          "Trigger": "`below_minimum_age_reject`, active safety flag from file 12 unresolved",
          "Behavior": "No program generation; human/professional referral message only"
        }
      ]
    },
    {
      "columns": [
        "Assessment",
        "Protocol",
        "Output Use"
      ],
      "rows": [
        {
          "Assessment": "Overhead squat assessment",
          "Protocol": "Bodyweight squat, arms overhead, observe from front/side",
          "Output Use": "Feeds mobility flag table (Section 4)"
        },
        {
          "Assessment": "Single-leg stance",
          "Protocol": "10s hold each leg, eyes open",
          "Output Use": "Feeds unilateral/balance-work prioritization"
        },
        {
          "Assessment": "Push/pull baseline",
          "Protocol": "Max unbroken push-ups; max unbroken rows (band or bodyweight)",
          "Output Use": "Establishes starting point for beginners without load-based 1RM"
        },
        {
          "Assessment": "Submaximal load test (3\u20135RM)",
          "Protocol": "For clients with some barbell experience only",
          "Output Use": "Feeds `estimated_1RM` used in file 2 Section 18"
        },
        {
          "Assessment": "Grip/core endurance",
          "Protocol": "Plank hold to failure (cap test at 120s)",
          "Output Use": "Baseline for core programming, not a competitive metric"
        }
      ]
    },
    {
      "columns": [
        "Observed Limitation",
        "Flag",
        "Programming Response"
      ],
      "rows": [
        {
          "Observed Limitation": "Heels rise during squat",
          "Flag": "`ankle_mobility_limited`",
          "Programming Response": "Elevate heels (wedge/plates) initially, add ankle dorsiflexion mobility work, prefer box squat/goblet squat"
        },
        {
          "Observed Limitation": "Excessive forward lean during squat",
          "Flag": "`hip_ankle_mobility_limited`",
          "Programming Response": "Prefer front-loaded squat variants (goblet, front squat), add thoracic/hip mobility work"
        },
        {
          "Observed Limitation": "Arms can't reach overhead without lower back arching",
          "Flag": "`thoracic_mobility_limited`",
          "Programming Response": "Cap OHP range temporarily, use landmine press, add thoracic extension mobility work"
        },
        {
          "Observed Limitation": "Rounded shoulders/forward head at rest",
          "Flag": "`postural_imbalance`",
          "Programming Response": "Increase horizontal pull:push ratio to 1.5:1, add face pulls/rear delt work"
        },
        {
          "Observed Limitation": "Can't maintain neutral spine in hinge",
          "Flag": "`hinge_pattern_incompetent`",
          "Programming Response": "Delay loaded hinge work, use hinge drills (dowel, wall-tap RDL) for 2\u20134 weeks first"
        },
        {
          "Observed Limitation": "Knees cave inward under load (valgus)",
          "Flag": "`hip_stability_limited`",
          "Programming Response": "Add banded lateral walks/clamshells, cue \"knees out,\" reduce load until pattern clean"
        },
        {
          "Observed Limitation": "Asymmetric single-leg stance hold (>3s difference)",
          "Flag": "`unilateral_imbalance`",
          "Programming Response": "Prioritize unilateral work at higher frequency on weaker side, screen for injury history"
        },
        {
          "Observed Limitation": "Pain (not just limitation) during any screen",
          "Flag": "`pain_provoking_movement`",
          "Programming Response": "Do NOT program that pattern; route to file 12 Section on pain-vs-limitation triage"
        }
      ]
    },
    {
      "columns": [
        "Item",
        "Frequency"
      ],
      "rows": [
        {
          "Item": "Bodyweight",
          "Frequency": "Weekly (same conditions: morning, post-bathroom, pre-food)"
        },
        {
          "Item": "Circumference measurements / photos",
          "Frequency": "Every 4 weeks"
        }
      ]
    },
    {
      "columns": [
        "Item",
        "Frequency"
      ],
      "rows": [
        {
          "Item": "Strength baseline (submaximal test)",
          "Frequency": "Every 8\u201312 weeks, or at mesocycle boundary"
        },
        {
          "Item": "Full movement screen re-run",
          "Frequency": "Every 12 weeks, or after any new injury flag resolves"
        },
        {
          "Item": "Goal/intake schema full review",
          "Frequency": "Every 12 weeks or on major life-change disclosure"
        },
        {
          "Item": "Medical clearance re-confirmation",
          "Frequency": "Every 6 months if `pending_clearance` unresolved, or immediately on new condition disclosure"
        }
      ]
    },
    {
      "columns": [
        "Tier",
        "System Response"
      ],
      "rows": [
        {
          "Tier": "low_risk",
          "System Response": "Continue standard progression"
        },
        {
          "Tier": "moderate_risk",
          "System Response": "Reduce weekly volume 10\u201315%, send barrier-check prompt, offer schedule flexibility"
        },
        {
          "Tier": "high_risk",
          "System Response": "Downgrade to 2\u20133 day minimum-effective-dose template, shorten mesocycle to 2 weeks, emphasize habit consistency over performance metrics"
        }
      ]
    },
    {
      "columns": [
        "Edge Case",
        "Rule"
      ],
      "rows": [
        {
          "Edge Case": "Client refuses to disclose medical history",
          "Rule": "Do not proceed to full program generation; provide only general, low-intensity guidance and repeat the clearance request; document refusal"
        },
        {
          "Edge Case": "Client under 13",
          "Rule": "Reject onboarding entirely; recommend youth-specific in-person coaching/physical education programs, not this system"
        },
        {
          "Edge Case": "Intake data internally inconsistent (e.g., claims \"5 years experience\" but fails all movement screens)",
          "Rule": "Weight movement screen results over self-report (see file 9 Section on troubleshooting); flag discrepancy"
        },
        {
          "Edge Case": "Client stops submitting check-ins entirely",
          "Rule": "After 2 missed check-in cycles, downgrade confidence in all readiness-based algorithms system-wide; default to conservative (yellow/orange tier) assumptions until data resumes"
        },
        {
          "Edge Case": "Body fat % provided is wildly inconsistent with other data",
          "Rule": "Flag `body_fat_estimate_unreliable`, fall back to sex+activity-based default ranges (file 7) rather than trusting the specific number"
        },
        {
          "Edge Case": "Client discloses new medical condition mid-program",
          "Rule": "Immediately re-run `processIntake` routing logic; do not wait for scheduled re-assessment"
        },
        {
          "Edge Case": "Client provides contradictory pregnancy status over time",
          "Rule": "Always trust most recent disclosure; re-flag `medical_clearance_required` immediately, do not require re-onboarding delay"
        },
        {
          "Edge Case": "Minor's guardian has not co-signed waiver",
          "Rule": "Block program generation until guardian consent recorded; status = `blocked_no_consent`"
        },
        {
          "Edge Case": "Client requests deletion of health data",
          "Rule": "Purge `health` object per data policy; downgrade to orange tier (no medical context = conservative default) until re-supplied"
        }
      ]
    },
