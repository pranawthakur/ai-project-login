          "Why Flagged": "Risk with unsupervised free-weight/overhead loading"
        },
        {
          "Condition": "Untreated cardiac arrhythmia",
          "Why Flagged": "Risk with high-intensity/max-effort work"
        },
        {
          "Condition": "Current DVT/blood clot history (unmanaged)",
          "Why Flagged": "Risk with Valsalva and prolonged static positions"
        }
      ]
