        "Likely Cause",
        "Fix"
      ],
      "rows": [
        {
          "Symptom": "Program stuck at `pending_clearance` indefinitely",
          "Likely Cause": "No re-prompt loop implemented",
          "Fix": "Trigger clearance re-request every session per Section 8"
        },
        {
          "Symptom": "Movement screen contradicts self-reported training age",
          "Likely Cause": "Self-report bias/overestimation",
          "Fix": "Default to screen results, flag discrepancy, do not block program"
        },
        {
          "Symptom": "Repeated `incomplete_intake_low_confidence`",
