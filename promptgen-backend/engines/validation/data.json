{
  "0_Master_Index_Versioning_and_Localization.md": [
    {
      "columns": [
        "File",
        "Role",
        "Depends On (reads)",
        "Produces (writes to client_state)"
      ],
      "rows": [
        {
          "File": "1. Master Workout Split Table",
          "Role": "Split selection",
          "Depends On (reads)": "11 (goals, schedule, tier), 8 (volume)",
          "Produces (writes to client_state)": "`active_split`"
        },
        {
          "File": "2. Programming Rules",
          "Role": "Sets/reps/RIR/progression",
          "Depends On (reads)": "11 (baseline, tier), 10 (recovery)",
          "Produces (writes to client_state)": "`prescription_variables`"
        },
        {
          "File": "3. Beginner Programming",
          "Role": "Beginner-specific rules",
          "Depends On (reads)": "11 (training age)",
          "Produces (writes to client_state)": "Beginner program overlay"
        },
        {
          "File": "4. Intermediate Programming",
          "Role": "Intermediate rules",
          "Depends On (reads)": "11, 2",
          "Produces (writes to client_state)": "Intermediate program overlay"
        },
        {
          "File": "5. Advanced Programming",
          "Role": "Advanced rules",
          "Depends On (reads)": "11, 2, 6",
          "Produces (writes to client_state)": "Advanced program overlay"
        },
        {
          "File": "6. Intensity Techniques",
          "Role": "Advanced techniques",
          "Depends On (reads)": "11 (tier gate: green only)",
          "Produces (writes to client_state)": "Technique injection into session"
        },
        {
          "File": "7. Goal-Based Modifications",
          "Role": "Nutrition/training goal skew",
          "Depends On (reads)": "11 (goals), 12 (ED flags block numeric targets)",
          "Produces (writes to client_state)": "`nutrition_targets`, goal-specific volume skew"
        },
        {
          "File": "8. Weekly Muscle Volume",
          "Role": "Volume landmarks",
          "Depends On (reads)": "11 (training age), 10 (recovery)",
          "Produces (writes to client_state)": "`volume_targets`"
        },
        {
          "File": "9. Exercise Selection Rules",
          "Role": "Exercise picking/substitution",
          "Depends On (reads)": "11 (equipment, mobility flags), 12 (pain triage)",
          "Produces (writes to client_state)": "`exercise_list`"
        },
        {
          "File": "10. Recovery & Deload",
          "Role": "Fatigue/deload logic",
          "Depends On (reads)": "11 (check-ins)",
          "Produces (writes to client_state)": "`recovery_score`, deload triggers"
        },
        {
          "File": "11. Assessment & Intake Engine",
          "Role": "Entry point, tiering",
          "Depends On (reads)": "(raw client input)",
          "Produces (writes to client_state)": "`client_state` root object, `confidence_tier`, `flags[]`"
        },
        {
          "File": "12. Safety & Medical Red-Flag Engine",
          "Role": "Cross-cutting safety gate",
          "Depends On (reads)": "11 (health data)",
          "Produces (writes to client_state)": "`safety_gate_result`, hard blocks/restrictions"
        },
        {
          "File": "13. Cardio & Conditioning",
          "Role": "Cardio prescription",
          "Depends On (reads)": "11, 12 (flags), 10 (recovery)",
          "Produces (writes to client_state)": "`cardio_prescription`"
        },
        {
          "File": "14. Default Safe Template & Coach Override",
          "Role": "Fallback program + human override",
          "Depends On (reads)": "11, 12",
          "Produces (writes to client_state)": "`DEFAULT_SAFE_TEMPLATE` object, `override_log[]`"
        },
        {
          "File": "15. Supplement Safety & Interaction Engine",
          "Role": "Supplement guidance",
          "Depends On (reads)": "11 (health/meds), 12 (interaction flags)",
          "Produces (writes to client_state)": "`supplement_guidance`"
        },
        {
          "File": "16. Exercise Intelligence Database",
          "Role": "Per-exercise data model + selection engine",
          "Depends On (reads)": "11 (equipment, mobility flags, tier), 12 (pain flags)",
          "Produces (writes to client_state)": "`exercise_id` objects, selection confidence scores"
        },
        {
          "File": "17. Periodization & AI Decision Engine",
          "Role": "Split/periodization selection, advanced set-structure definitions, shared confidence formula",
          "Depends On (reads)": "1, 2, 8, 10, 11, 16",
          "Produces (writes to client_state)": "`active_split` (scored), periodization model, confidence scores used across files"
        },
        {
          "File": "18. Injury-Specific Rehabilitation & Return-to-Training",
          "Role": "Per-injury (acute/soft-tissue) protocols and phased return-to-load",
          "Depends On (reads)": "11, 12 (gate precedence)",
          "Produces (writes to client_state)": "Injury phase, session modifications, reintroduction schedule"
        },
        {
          "File": "19. Chronic Health Condition Management Engine",
          "Role": "Per-condition (diabetes, hypertension, asthma, OA, PCOS, thyroid) ongoing programming rules",
          "Depends On (reads)": "11, 12 (gate precedence), 13, 10",
          "Produces (writes to client_state)": "Condition-specific modifications, stability monitoring flags"
        },
        {
          "File": "20. Acute Symptom & First-Response Triage Engine",
          "Role": "Front-door classification/dispatch for any newly reported health issue",
          "Depends On (reads)": "12, 18, 19",
          "Produces (writes to client_state)": "Classification + handoff target + today's-session decision"
        }
      ]
    },
    {
