# --- Supabase ---
SUPABASE_URL=https://yabclxadadynmprymcns.supabase.co
SUPABASE_JWT_SECRET=PASTE_YOUR_LEGACY_JWT_SECRET_HERE
SUPABASE_SERVICE_ROLE_KEY=PASTE_YOUR_SERVICE_ROLE_KEY_HERE
DEMO_GYM_ID=3f80f512-5156-4a48-8c49-4f617ce77256
# ^ Now a FALLBACK, not the only gym. Members reach here via a plain login
# (no ?gym= / X-Gym-Slug) still land in this gym, same as before. Members
# who arrive via a gym-specific access link (see app/gym_scope.py) get
# scoped to that gym's real id instead.

# --- Member sessions ---
# Signs this app's own member session tokens, issued by POST /member/login
# or POST /member/set-password (see app/auth.py). Members no longer sign up
# via Supabase Auth at all — this is the only thing authenticating them.
# Required for member login to work; unset -> 503. Generate with e.g.
# `python -c "import secrets; print(secrets.token_urlsafe(32))"`
MEMBER_SESSION_SECRET=

# --- Phase 2: member password auth ---
# No new env var required — passwords are hashed with bcrypt and stored in
# the `members.password_hash` column (see migrations/phase2_add_password_hash.sql
# in this same repo folder). `bcrypt` has been added to requirements.txt.
# One thing still needed before this works in a real deployment: run that
# migration against Supabase (adds the nullable column) — nothing here
# does that automatically.

# --- Dev-console integration ---
# Shared secret for POST /generate/test (see app/main.py). Leave blank to
# keep that route disabled. Must match whatever the dev-console's
# ai_testing.py sends as X-Dev-Test-Key once that's wired up.
DEV_TEST_KEY=

# Where GET /member/login redirects to (see app/main.py). This is the
# ai-project-login Vercel deploy's real URL - project #2, NOT
# admin-dashboard-backend's separate Vercel project. Required for
# /member/login to work at all; unset -> 503.
MEMBER_FRONTEND_URL=

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Gemini ---
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

# --- CORS: which frontend origins are allowed to call this backend ---
FRONTEND_ORIGIN=http://127.0.0.1:5500,https://ai-project-login-44q4.vercel.app
